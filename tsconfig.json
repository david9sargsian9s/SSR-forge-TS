{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "moduleResolution": "Node",

    "target": "ES2022",

    "esModuleInterop": true,

    "sourceMap": true,
    "declaration": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}